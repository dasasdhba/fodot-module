<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>$(TargetFrameworkVersion)</TargetFramework>
        <GenerateDocumentationFile>$(DocumentationFileFlag)</GenerateDocumentationFile>
        <RootNamespace>Fodot.Injection</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Bind.fs" />
        <Compile Include="OwnerMeta.fs" />
        <Compile Include="Res.fs" />
        <Compile Include="Compo.fs" />
        <Compile Include="Injector.fs" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\library\Fodot.Extend\Fodot.Extend.fsproj" />
    </ItemGroup>

</Project>
